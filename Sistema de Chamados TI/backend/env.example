# Copie para backend/.env e ajuste os valores.
# IMPORTANTE: use o MESMO DATABASE_URL da raiz do monorepo (.env do Gerenciamento).

# Banco – PostgreSQL compartilhado com Gerenciamento de Telefones (monorepo).
# Ex.: postgresql://postgres:senha@localhost:5432/gerenciamento_telefones
# Docker local (raiz do projeto): docker compose up -d
# SQLite somente legado: DATABASE_URL=sqlite:///./chamados.db
DATABASE_URL=postgresql://postgres:SUA_SENHA@localhost:5432/gerenciamento_telefones

# JWT
SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION=3600
JWT_REFRESH_EXPIRATION=86400

# Email
SMTP_HOST=email-ssl.com.br
SMTP_PORT=587
SMTP_USER=seu-email@promio.com.br
SMTP_PASSWORD=sua-senha
SMTP_FROM=noreply@promio.com.br
SMTP_USE_TLS=True

# Cadastro público: DDD usado quando o usuário informa só o telefone sem DDD (ex.: 11)
PORTAL_DEFAULT_DDD=11

# Application
API_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
STREAMLIT_APP_URL=http://localhost:8501
DEBUG=True
ENVIRONMENT=development

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Snipe-IT (opcional)
SNIPE_BASE_URL=
SNIPE_API_TOKEN=
SNIPE_STATUS_READY_ID=1
SNIPE_STATUS_MAINTENANCE_ID=2

# Integração desligamento ↔ linhas (mesmo PostgreSQL quando DATABASE_URL é postgres)
TELEFONES_SYNC_ENABLED=True
# Só necessário se DATABASE_URL for SQLite (caminho do .db do telefones)
TELEFONES_DB_PATH=
