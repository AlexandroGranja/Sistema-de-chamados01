# Variáveis de ambiente — monorepo Gerenciamento + Chamados
#
# 1. Copie este arquivo para `.env` na RAIZ do repositório (Gerenciamento Streamlit).
# 2. Copie os mesmos valores de DATABASE_URL para:
#    `Sistema de Chamados TI/backend/.env`
# 3. Ajuste senhas e URLs conforme o ambiente (dev/prod).

# ---------------------------------------------------------------------------
# Banco compartilhado (PostgreSQL) — OBRIGATÓRIO para integração
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:SUA_SENHA@localhost:5432/gerenciamento_telefones

# ---------------------------------------------------------------------------
# Gerenciamento de Telefones (Streamlit — porta 8501)
# ---------------------------------------------------------------------------
APP_TIMEZONE=America/Sao_Paulo
COOKIES_PASSWORD=planilhas_telefones_secret_2024

# URL do frontend React dos Chamados (SSO e links de retorno)
# Dev com ativador_completo.bat: http://localhost:3000
CHAMADOS_APP_URL=http://localhost:3000

# URL do Gerenciamento de Telefones (Streamlit) — links do React para edição manual
STREAMLIT_APP_URL=http://localhost:8501

# ---------------------------------------------------------------------------
# Referência — Sistema de Chamados TI (backend/.env)
# Copie DATABASE_URL acima e adicione no backend:
# ---------------------------------------------------------------------------
# SECRET_KEY=your-secret-key-change-in-production
# API_URL=http://localhost:8000
# FRONTEND_URL=http://localhost:3000
# TELEFONES_SYNC_ENABLED=True
# Ver: Sistema de Chamados TI/backend/env.example
