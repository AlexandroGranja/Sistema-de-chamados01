# =============================================================================
# GERENCIAMENTO DE TELEFONES + SISTEMA DE CHAMADOS TI
# Copie este arquivo para .env e preencha os valores antes de iniciar.
# NUNCA commite o arquivo .env — ele está no .gitignore.
# =============================================================================

# --- Banco de dados PostgreSQL ---
# Formato: postgresql://usuario:senha@host:porta/banco
# Se a senha contiver $ use %24 no lugar (ex: minhas%24enha)
DATABASE_URL=postgresql://postgres:SUA_SENHA@localhost:5432/gerenciamento_telefones

# --- Segurança dos cookies do Streamlit ---
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
COOKIES_PASSWORD=GERE_UMA_SENHA_FORTE_AQUI

# --- Segurança dos tokens JWT (API de Chamados) ---
# OBRIGATÓRIO — deve ser diferente de COOKIES_PASSWORD (chaves com propósitos distintos)
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=GERE_OUTRO_SEGREDO_FORTE_AQUI

# --- URLs de integração ---
CHAMADOS_APP_URL=http://localhost:5173

# --- E-mail SMTP (reset de senha + notificações de chamado) ---
# Locaweb: host e porta padrão já configurados
SMTP_HOST=email.locaweb.com.br
SMTP_PORT=587
SMTP_USER=suporte@prosperdistribuidora.com.br
SMTP_PASSWORD=SUA_SENHA_EMAIL_AQUI
SMTP_FROM=suporte@prosperdistribuidora.com.br

# --- URL pública do app Streamlit (usada nos links de reset de senha) ---
# Em produção: substitua pelo domínio real
APP_URL=http://localhost:8501

# --- Backend da API ---
CHAMADOS_API_HOST=0.0.0.0
CHAMADOS_API_PORT=8000

# --- CORS: origens permitidas pela API (separadas por vírgula) ---
# Em produção substitua pelos domínios reais do servidor
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8501

# --- HTTPS (produção) ---
# Defina como "true" quando o servidor tiver SSL/TLS configurado
FORCE_HTTPS=false

# --- JWT TTL (opcional) ---
# JWT_ACCESS_EXPIRES_SECONDS=900      # 15 minutos (padrão)
# JWT_REFRESH_EXPIRES_SECONDS=2592000 # 30 dias (padrão)

# --- Fuso horário ---
APP_TIMEZONE=America/Sao_Paulo

# --- Ambiente: "development" habilita /docs no FastAPI; "production" desabilita ---
ENV=production
