FROM node:20-alpine AS build
WORKDIR /frontend
COPY ["Sistema de Chamados TI/frontend/package.json", "Sistema de Chamados TI/frontend/package-lock.json", "./"]
RUN npm ci
COPY ["Sistema de Chamados TI/frontend/", "./"]
RUN npm run build

FROM nginx:1.27-alpine
COPY deploy/nginx/frontend.conf /etc/nginx/conf.d/default.conf
COPY --from=build /frontend/dist /usr/share/nginx/html
EXPOSE 80
